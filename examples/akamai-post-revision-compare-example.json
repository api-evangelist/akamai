{
  "operationId": "post-revision-compare",
  "method": "POST",
  "path": "/ids/{edgeWorkerId}/revisions/{revisionId}/compare",
  "summary": "Akamai Compare Revisions",
  "requestExamples": [
    {
      "contentType": "application/json",
      "example": {
        "revisionId": "5-1"
      }
    }
  ],
  "responseExamples": [
    {
      "status": "200",
      "contentType": "application/json",
      "example": {
        "edgeWorkerId": 42,
        "version": "0.7",
        "dependencies": {
          "redirect-geo-query": {
            "diff": "UPDATED",
            "edgeWorkerId": 23,
            "previousVersion": "3.9",
            "version": "4.0"
          }
        }
      }
    }
  ]
}