{
  "operationId": "post-tokens",
  "method": "POST",
  "path": "/tokens",
  "summary": "Akamai Create an Access Token",
  "requestExamples": [
    {
      "contentType": "application/json",
      "example": {
        "allowOnProduction": false,
        "allowOnStaging": true,
        "expiry": "2021-09-30",
        "name": "my_token",
        "namespacePermissions": {
          "marketing": [
            "r",
            "w"
          ]
        }
      }
    }
  ],
  "responseExamples": [
