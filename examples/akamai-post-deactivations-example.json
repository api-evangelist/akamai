{
  "operationId": "post-deactivations",
  "method": "POST",
  "path": "/ids/{edgeWorkerId}/deactivations",
  "summary": "Akamai Deactivate an EdgeWorker Version",
  "requestExamples": [
    {
      "contentType": "application/json",
      "example": {
        "network": "PRODUCTION",
        "note": "EdgeWorker ID 42 is no longer used in production.",
        "version": "2"
      }
    }
  ],
  "responseExamples": [
    {
      "status": "201",
      "contentType": "application/json",
      "example": {
        "accountId": "A-CCT3456",
        "createdBy": "jsmith",
        "createdTime": "2020-04-05T18:17:46Z",
        "deactivationId": 3,
        "edgeWorkerId": 42,
        "lastModifiedTime": "2020-04-05T18:17:46Z",
        "network": "PRODUCTION",
        "note": "EdgeWorker ID 42 is no longer used in production.",
        "status": "PRESUBMIT",
        "version": "5"
      }
    }
  ]
}