        "headers": [
          {
            "name": "Content-Type",
            "value": "application/problem+json"
          }
        ]
      }
    }
  ],
  "responseExamples": [
    {
      "status": "200",
      "contentType": "application/json",
      "example": {
        "body": "{\"title\":\"The API key you provided does not exist.\" }",
        "overrideDefaults": false,
        "statusCode": 401,
        "headers": [
          {
            "name": "Content-Type",
            "value": "application/problem+json"
          }
        ]
      }
    }
  ]
