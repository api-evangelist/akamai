{
  "operationId": "put-cors-settings",
  "method": "PUT",
  "path": "/endpoints/{apiEndPointId}/versions/{versionNumber}/settings/cors",
  "summary": "Edit CORS settings",
  "requestExamples": [
    {
      "contentType": "application/json",
      "example": {
        "allowCredentials": false,
        "enabled": true,
        "preflightMaxAge": 86400,
        "allowedHeaders": [
          "Akamai-Cors-Allowed"
        ],
        "allowedMethods": [
          "GET"
        ],
        "allowedOrigins": [
          "*"
        ],
        "exposedHeaders": [
          "Akamai-Cors-Exposed"
        ]
      }
    }
  ],
  "responseExamples": [
    {
      "status": "200",
      "contentType": "application/json",
      "example": {
        "allowCredentials": false,
        "enabled": true,
        "preflightMaxAge": 86400,
        "allowedHeaders": [
          "Akamai-Cors-Allowed"
        ],
        "allowedMethods": [
          "GET"
        ],
        "allowedOrigins": [
          "*"
        ],
        "exposedHeaders": [
          "Akamai-Cors-Exposed"
        ]
      }
    }
  ]
}